entrypoint: {{ workflow_name }}
serviceAccountName: {{ workflow_service_account }}
{% if cron_schedule %}
volumes:
{% for vol in extraVolumeMounts %}
- name: {{ vol.name }}
  persistentVolumeClaim:
    claimName: {{ vol.name }}
{% endfor %}
{% endif %}
volumeClaimTemplates:
- metadata:
    name: workdir
  spec:
    accessModes: [ "ReadWriteMany" ]
    persistentVolumeReclaimPolicy: Delete
    resources:
      requests:
        storage: {{ workdir_storage_size }}
arguments:
  parameters:
  {% for payload_param in naavrewf2_payload_params %}
  - name: {{ payload_param.name }}_{{ payload_param.node_id[:7] }}
    value:  "{{ payload_param.value | replace('"', "'") }}"
  {% endfor %}
templates:
- name: {{ workflow_name }}
  dag:
    tasks:
    {% for node in nodes.values() %}
    {% set is_special_node = node.type == 'splitter' or node.type == 'merger' %}
    {% set is_splitter = node.type == 'splitter' %}
    {% set title =  node.type + "-" + node.id[:7] if is_special_node else node.properties.cell.title+ "-" + node.id[:7] %}
    - name: {{ title }}
      {% if deps_dag[node.id]|length > 0 %}
      dependencies: [{% for d in deps_dag[node.id] %} {{ d.task_name }}{% if not loop.last %},{% endif %} {% endfor %}]
      {% endif %}
      template: {{ title }}-tmp
      {% if deps_dag[node.id]|length > 0 %}
      arguments:
        parameters:
        {% for d in deps_dag[node.id] %}
        - name: {{ d.from_port }}
        {% if d.type == "splitter" %}
          value: {{ '"{{item}}"' }}
        {% else %}
          value: {{ '"{{tasks.' }}{{ d.task_name }}{{ '.outputs.parameters.' }}{{ d.from_port }}{{'}}"'}}
        {% endif %}
        {% endfor %}
        {% for payload_param in naavrewf2_payload_params %}
        - name : {{ payload_param.name }}_{{ payload_param.node_id[:7] }}
          value: {{ '"{{workflow.parameters.' }}{{ payload_param.name }}_{{ payload_param.node_id[:7] }}{{'}}"' }}
        {% endfor %}
      {% for d in deps_dag[node.id] %}
      {% if d.type == "splitter" %}
      withParam: {{ '"{{tasks.' }}{{ d.task_name }}{{ '.outputs.parameters.' }}{{ d.from_port }}{{'}}"'}}
      {% endif %}
      {% endfor %}
      {% endif %}
    {% endfor %}
{% for node in nodes.values() %}
{% set is_special_node = node.type == 'splitter' or node.type == 'merger' %}
{% set is_splitter = node.type == 'splitter' %}
{% set title = node.type + "-" + node.id[:7] if is_special_node else node.properties.cell.title + "-" + node.id[:7] %}
{% set secrets = [] if is_special_node else node.properties.cell.secrets %}
{% set ports = node.ports %}
- name: {{ title }}-tmp
  {% if deps_dag[node.id]|length > 0 %}
  inputs:
    parameters:
    {% for d in deps_dag[node.id] %}
    - name: {{ d.from_port }}
    {% endfor %}
    {% for payload_param in naavrewf2_payload_params %}
    - name: {{ payload_param.name }}_{{ payload_param.node_id[:7] }}
    {% endfor %}
  {% endif %}
  outputs:
    parameters:
    {% for port in ports.values() %}
    {% if port.type == 'right' %}
      - name: {{ port.id }}_{{ node.id[:7] }}
        valueFrom:
          path: /tmp/{{ port.id }}_{{ node.id[:7] }}.json
    {% endif %}
    {% endfor %}
  {% if is_special_node %}
  {% set special_dep = deps_dag[node.id][0] %}
  script:
    image: python:alpine3.9
    imagePullPolicy: IfNotPresent
    command: [python]
    source: |
      {% if is_splitter %}
      {{ include('splitter_logic.j2', ports=ports, special_dep=special_dep, node=node) | indent(6) }}
      {% else %}
      {{ include('merger_logic.j2', ports=ports, special_dep=special_dep,node=node) | indent(6) }}
      {% endif %}
  {% else %}
  container:
    image: "{{ node.properties.cell.container_image }}"
    imagePullPolicy: Always
    volumeMounts:
    - name: workdir
      mountPath: /tmp/data
    {% if extraVolumeMounts is defined %}
    {% for vol in extraVolumeMounts %}
    - name: {{ vol.name }}
      mountPath: {{ vol.mountPath }}
      {% if vol.subPath is defined %}
      subPath: {{ vol.subPath }}
      {% endif %}
      {% if vol.readOnly is defined %}
      readOnly: {{ vol.readOnly }}
      {% endif %}
    {% endfor %}
    {% endif %}
    env:
    {%  for s in secrets %}
      - name: {{ s.name }}
        valueFrom:
          secretKeyRef:
            name: {{ k8s_secret_name }}
            key: {{ s.name }}
    {%  endfor %}
    command: ["/bin/bash", "-c"]
    args:
      - source /venv/bin/activate;
    {% if node.properties.cell.kernel == 'ipython' %}
        python /app/task.py
    {% elif node.properties.cell.kernel == 'IRkernel' %}
        Rscript /app/task.R
    {% endif %}
        {% for d in deps_dag[node.id] %}
        {% set is_from_special = d.type == 'splitter' or  d.type == 'merger' %}
        {% set std_in_name = d.to_port %}
        {% set std_in_name_base = std_in_name.split('_')[:-1]|join('_') %}
        --{{ std_in_name_base }}='{{ '{{inputs.parameters.' }}{{ d.from_port }}{{ '}}' }}'
        {% endfor %}
        {% for cell_params in node.properties.cell.params %}
        --{{ cell_params.name }}={{ '"{{workflow.parameters.' }}{{ cell_params.name }}_{{ node.id[:7] }}{{ '}}"' }}
        {% endfor %}
        --id={{ node.id[:7] }};
  {% endif %}
{% endfor %}