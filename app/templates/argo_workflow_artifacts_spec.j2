entrypoint: {{ workflow_name }}
serviceAccountName: {{ workflow_service_account }}
{% if cron_schedule %}
volumes:
{% for vol in extraVolumeMounts %}
- name: {{ vol.name }}
  persistentVolumeClaim:
    claimName: {{ vol.name }}
- name: workspace
  emptyDir:
    medium: Memory
{% endfor %}
{% endif %}
volumeClaimTemplates:
- metadata:
    name: workdir
  spec:
    accessModes: [ "ReadWriteMany" ]
    persistentVolumeReclaimPolicy: Delete
    resources:
      requests:
        storage: {{ workdir_storage_size }}
arguments:
  parameters:
  {% for payload_param in naavrewf2_payload_params %}
  - name: {{ payload_param.name }}_{{ payload_param.node_id[:7] }}
    value:  "{{ payload_param.value | replace('"', "'") }}"
  {% endfor %}
templates:
- name: {{ workflow_name }}
  dag:
    tasks:
    {% set parameters = [] %}
    {% set artifacts = [] %}
    {% set updated_dependencies_dag = [] %}
    {% for node in nodes.values() %}
    {% set is_special_node = node.type == 'splitter' or node.type == 'merger' %}
    {% set is_splitter = node.type == 'splitter' %}
    {% set title =  node.type + "-" + node.id[:7] if is_special_node else node.properties.cell.title+ "-" + node.id[:7] %}
    - name: {{ title }}
      {% if dependencies_dag[node.id]|length > 0 %}
      dependencies: [{% for d in dependencies_dag[node.id] %} {{ d.task_name }}{% if not loop.last %},{% endif %} {% endfor %}]
      {% endif %}
      template: {{ title }}-tmp
      {% if dependencies_dag[node.id]|length > 0 %}
        {% for dependency in dependencies_dag[node.id] %}
        {% set new_dependency = dependency %}
        {% if dependency.type == "splitter" %}
          {% set parameter = {'name': dependency.from_port,
                              'value': '"{{item}}"',
                              'withParam': '"{{tasks.' + dependency.task_name + '.outputs.parameters.' + dependency.from_port +'}}"',
                              'to_task': title,
                              'from_task': dependency.task_name} %}
          {% set _ = parameters.append(parameter) %}
          {% set new_dependency.is_artifact = False %}
        {% else %}
          {% set artifact = {'name': dependency.from_port,
                             'from':  '"{{tasks.'+ dependency.task_name +'.outputs.artifacts.'+dependency.from_port +'}}"',
                             'to_task': title,
                             'from_task': dependency.task_name} %}
          {% set _ = artifacts.append(artifact) %}
        {% endif %}
        {% set _ = updated_dependencies_dag.append(new_dependency) %}
        {% endfor %}
        {% for payload_param in naavrewf2_payload_params %}
        {% if payload_param.node_id == node.id %}
          {% set parameter = {'name': payload_param.name+'_'+payload_param.node_id[:7],
                              'value': '"{{workflow.parameters.' + payload_param.name +'_'+ payload_param.node_id[:7] +'}}"',
                              'to_task': title,
                              'from_task': payload_param.name+'_'+payload_param.node_id[:7]} %}
          {% set _ = parameters.append(parameter) %}
        {% endif %}
        {% endfor %}
      {% if artifacts or parameters %}
      arguments:
      {% endif %}
      {% if parameters %}
        parameters:
        {% for parameter in parameters %}
        {% if  title == parameter.to_task %}
        - name: {{ parameter.name }}
          value: {{ parameter.value }}
          {% if parameter.withParam is defined %}
            {%  set withParam = parameter.withParam %}
          {% endif %}
        {% endif %}
      {% if withParam is defined %}
      withParam: {{ withParam }}
      {% endif %}
       {% endfor %}
      {% endif %}
      {% if artifacts | length > 0 %}
        artifacts:
        {% for artifact in artifacts %}
        - name: {{ artifact.name }}
          from: {{ artifact.from }}
        {% endfor %}
      {% endif %}
      {% endif %}
    {% endfor %}

{% for node in nodes.values() %}
{% set is_special_node = node.type == 'splitter' or node.type == 'merger' %}
{% set is_splitter = node.type == 'splitter' %}
{% set title = node.type + "-" + node.id[:7] if is_special_node else node.properties.cell.title + "-" + node.id[:7] %}
{% set secrets = [] if is_special_node else node.properties.cell.secrets %}
{% set ports = node.ports %}
- name: {{ title }}-tmp
  {% if dependencies_dag[node.id]|length > 0 %}
  inputs:
    {% if parameters %}
    parameters:
    {% for parameter in parameters %}
    {% if  title == parameter.to_task %}
    - name: {{ parameter.name }}
    {% endif %}
    {% endfor %}
    {% endif %}
    {% if artifacts %}
    artifacts:
    {% for artifact in artifacts %}
    {% if  title == artifact.to_task %}
    - name: {{ artifact.name }}
      path: /tmp/{{ artifact.name }}.json
    {% endif %}
    {% endfor %}
    {% endif %}
  {% endif %}
  outputs:
    {% if parameters %}
    parameters:
    {% for parameter in parameters %}
    {% if  title == parameter.from_task %}
      - name: {{ parameter.name }}
        valueFrom:
            path: /tmp/{{ parameter.name }}.json
    {% endif %}
    {% endfor %}
    {% endif %}
    {% if artifacts %}
    artifacts:
    {% for artifact in artifacts %}
    {% if  title == artifact.from_task %}
      - name: {{ artifact.name }}
        path: /tmp/{{ artifact.name }}.json
    {% endif %}
    {% endfor %}
    {% endif %}

  {% if is_special_node %}
  {% set special_dep = dependencies_dag[node.id][0] %}
  script:
    image: python:alpine3.9
    imagePullPolicy: IfNotPresent
    command: [python]
    source: |
      {% if is_splitter %}
      {{ include('splitter_logic.j2', ports=ports, special_dep=special_dep, node=node, naavrewf2_payload_params=naavrewf2_payload_params, default_max_branches=default_max_branches,has_artifact=True) | indent(6) }}
      {% else %}
      {{ include('merger_logic.j2', ports=ports, special_dep=special_dep,node=node,has_artifact=True) | indent(6) }}
      {% endif %}
  {% else %}
  containerSet:
    volumeMounts:
    - name: workspace
      mountPath: /workspace
    - name: workdir
      mountPath: /tmp/data
    {% if extraVolumeMounts is defined %}
    {% for vol in extraVolumeMounts %}
    - name: {{ vol.name }}
      mountPath: {{ vol.mountPath }}
      {% if vol.subPath is defined %}
      subPath: {{ vol.subPath }}
      {% endif %}
      {% if vol.readOnly is defined %}
      readOnly: {{ vol.readOnly }}
      {% endif %}
    {% endfor %}
    {% endif %}
    containers:
      - name: main
        image: "{{ node.properties.cell.container_image }}"
        imagePullPolicy: Always
        dependencies:
            - init-input-args-{{ title }}
        env:
        {%  for s in secrets %}
        - name: {{ s.name }}
            valueFrom:
            secretKeyRef:
                name: {{ k8s_secret_name }}
                key: {{ s.name }}
        {%  endfor %}
        command: ["/bin/bash", "-c"]
        args:
          - source /venv/bin/activate;
            {% if node.properties.cell.kernel == 'ipython' %}
            {% set cmd = 'python /app/task.py' %}
            {% elif node.properties.cell.kernel == 'IRkernel' %}
            {% set cmd = 'Rscript /app/task.R' %}
            {% endif %}
            {%  if  node.properties.cell.json_args_supported %}
            cat /workspace/{{ node.id[:7] }}/inputs.json;
            {{  cmd }} --args_json /workspace/{{ node.id[:7] }}/inputs.json;
            {%  else %}
            xargs -0 {{  cmd }} < /workspace/{{ node.id[:7] }}/inputs.txt
            {%  endif %}
      - name: init-input-args-{{ title }}
        image: python:alpine3.9
        command: ["python", "-c"]
        args:
        - |
          {{ include('init_container_logic.j2', dependencies_dag=dependencies_dag,node=node,has_artifact=True) | indent(10) }}
  {% endif %}
{% endfor %}