import json
import os
import shlex
args = []
{% for dependency in dependencies_dag[node.id] %}
{% set is_from_special = dependency.type == 'splitter' or  dependency.type == 'merger' %}
{% set input_name = dependency.to_port %}
{% set input_name_base = input_name.split('_')[:-1]|join('_') %}
{% for cell_input in node.properties.cell.inputs if cell_input.name == input_name_base %}
value = {{ '{{inputs.parameters.' }}{{ dependency.from_port }}{{ '}}' }}
if not isinstance(value, str):
    val = str(value)
arg = {
   "name": "{{ input_name_base }}",
   "type": "{{ cell_input.type }}",
   "value": str(value)
}
args.append(arg)
{% endfor %}
{% endfor %}
{% for cell_params in node.properties.cell.params %}
arg = {
    "name": "{{ cell_params.name }}",
    "type": "{{ cell_params.type }}",
    "value": "{{ '{{workflow.parameters.' }}{{ cell_params.name }}_{{ node.id[:7] }}{{ '}}' }}"
}
args.append(arg)
{% endfor %}
arg = {
    "name": "id",
    "type": "str",
    "value": "{{ node.id[:7] }}"
}
args.append(arg)
# Crate a folder with the node id if it doesn't exist in /workspace
workspace_dir = '/workspace/{{ node.id[:7] }}'
if not os.path.exists(workspace_dir):
    os.makedirs(workspace_dir)
with open(workspace_dir + '/' + 'inputs.json', 'w') as f:
    json.dump(args, f)

# Convert to flat arguments with proper shell escaping
inputs = ''
for arg in args:
  name = arg.get('name')
  value = arg.get('value')
  print(f"Processing argument: name={name}, value={value}")
  line = f"--{name}={shlex.quote(str(value))}"
  print(f"Converted to flat argument: {line}")
  inputs += line + ' '

# Write the flat arguments to a file
with open(workspace_dir+'/inputs.txt', 'w') as f:
    f.write(inputs)