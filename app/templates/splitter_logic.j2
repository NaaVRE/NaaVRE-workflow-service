import json
{{ special_dep.from_port }} = {{ '{{inputs.parameters.' }}{{ special_dep.from_port }}{{ '}}' }}
{% for port in ports.values() %}
{% if port.type == 'right' %}

max_workers = {{ max_workers | default(100) }}
{{ param_max_branches }} = min(batch_size, len({{ special_dep.from_port }}), max_workers)
items_per_worker = len({{ special_dep.from_port }}) // batch_size
overflow = len({{ special_dep.from_port }}) % batch_size
list_of_lists = []

for i in range({{ param_max_branches }}):
    chunk = items_per_worker
    if i < overflow:
        chunk = items_per_worker + 1
        start = i * chunk
    else:
        start = (i * chunk) + overflow
    end = start + chunk
    list_of_lists.append({{ special_dep.from_port }}[start:end])


f_out = open("/tmp/{{port.id}}_{{ node.id[:7] }}.json", "w")
f_out.write(json.dumps(list_of_lists))
f_out.close()
{% endif %}
{% endfor %}